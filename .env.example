# =============================================================================
# cGR8s - Comprehensive Goods Reconciliation at Secondary
# Environment Configuration
# =============================================================================

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-strong-random-secret-in-production
PORT=5053

# =============================================================================
# Database - Microsoft SQL Server
# =============================================================================
# Connection mode: 'sql' for SQL Server Auth, 'windows' for Windows Auth
DB_AUTH_MODE=windows

# SQL Server connection details
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=localhost
DB_NAME=cGR8s
DB_PORT=1433

# SQL Server Authentication (only used when DB_AUTH_MODE=sql)
DB_USER=sa
DB_PASSWORD=your-db-password

# Connection Pool
DB_POOL_SIZE=10
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30
DB_MAX_OVERFLOW=5

# =============================================================================
# External Auth App Integration (Auth-first / SSO)
# =============================================================================
# Auth Platform base URL (used by SDK for token validation + page sync)
AUTH_APP_URL=http://ams-it-126:5000

# API key issued by the Auth Platform for server-to-server calls
AUTH_APP_API_KEY=your-api-key-from-auth-app

# HTTP timeout for Auth Platform calls (seconds)
AUTH_APP_TIMEOUT=10

# Application identity in Auth-App (UUID from the applications table)
AUTH_APP_APPLICATION_ID=50000000-0000-0000-0000-000000000008

# =============================================================================
# Report & Export
# =============================================================================
REPORT_OUTPUT_DIR=reports
REPORT_TEMPLATE_DIR=app/reports/templates
MAX_BATCH_SIZE=500

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/cgr8s.log

# =============================================================================
# Batch Processing
# =============================================================================
BATCH_WORKER_THREADS=3
BATCH_CHUNK_SIZE=50
BATCH_RETRY_MAX=3
